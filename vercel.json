{
  "version": 2,
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/video/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/favicon(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/manifest.webmanifest",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    },
    {
      "source": "/(sitemap.xml|products-feed.xml|robots.txt)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=600" }
      ]
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/sitemap.xml", "dest": "/api/sitemap" },
    { "src": "/(om|sa)/sitemap.xml", "dest": "/api/sitemap" },
    { "src": "/(om|sa)/products-feed.xml", "dest": "/products-feed.xml" },
    { "src": "/(om|sa)/robots.txt", "dest": "/robots.txt" },
    { "src": "/(om|sa)/manifest.webmanifest", "dest": "/manifest.webmanifest" },
    { "src": "/(.*\\.(?:js|css|png|jpg|jpeg|gif|ico|svg|webp|mp4|webm|ogg|woff|woff2|ttf|eot|json|xml|txt|webmanifest))", "dest": "/$1" },
    { "src": "/(.*)", "dest": "/api/ssr" }
  ]
}
